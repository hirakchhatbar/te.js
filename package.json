{
  "name": "te.js",
  "version": "2.4.0",
  "description": "AI Native Node.js Framework",
  "type": "module",
  "main": "te.js",
  "bin": {
    "tejas": "cli/index.js"
  },
  "scripts": {
    "start": "node te.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "author": "Hirak",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.12.5",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "3.2.5",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/hirakchhatbar/te.js.git"
  },
  "files": [
    "te.js",
    "cli",
    "cors",
    "radar",
    "server",
    "database",
    "rate-limit",
    "utils",
    "lib",
    "auto-docs",
    "README.md",
    "docs"
  ],
  "dependencies": {
    "ansi-colors": "^4.1.3",
    "filesize": "^10.1.1",
    "formidable": "^3.5.1",
    "mime": "^4.0.1",
    "statuses": "^2.0.1",
    "tej-env": "^1.1.3",
    "tej-logger": "^1.3.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm test"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "pretty-quick --staged",
      "eslint --fix"
    ]
  }
}
